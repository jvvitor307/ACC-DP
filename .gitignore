# --- Binários e Executáveis ---
# Binários gerados pelo comando 'go build'
*.exe
*.exe~
*.dll
*.so
*.dylib
# Binário principal (ajuste se seu binário tiver um nome específico, ex: /my-app)
bin/
out/

# --- Testes e Cobertura ---
# Perfis de CPU e Memória
*.test
*.out
*.prof
# Arquivos de cobertura (ex: gerados por go test -coverprofile=coverage.out)
coverage.txt
coverage.html

# --- Dependências ---
# A pasta vendor/ só deve ser commitada se você tiver requisitos estritos de 
# reprodutibilidade offline (Enterprise). Caso contrário, ignore-a.
# vendor/

# --- IDEs e Editores ---
.vscode/
.idea/
*.swp
*.swo

# --- Variáveis de Ambiente ---
.env
.env.local

# --- Sistema Operacional ---
.DS_Store
Thumbs.db