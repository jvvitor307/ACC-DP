# Redpanda
REDPANDA_BROKERS=localhost:19092
SCHEMA_REGISTRY_URL=http://localhost:18081
REDPANDA_EXTERNAL_HOST=localhost

# Docker images and containers
REDPANDA_IMAGE=docker.redpanda.com/redpandadata/redpanda:v24.3.9
REDPANDA_CONTAINER_NAME=redpanda
REDPANDA_CONSOLE_IMAGE=docker.redpanda.com/redpandadata/console:v2.8.2
REDPANDA_CONSOLE_CONTAINER_NAME=redpanda-console
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z
MINIO_CONTAINER_NAME=minio
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-01-17T23-25-50Z
MINIO_MC_CONTAINER_NAME=minio-mc
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=postgres
BACKEND_CONTAINER_NAME=backend

# Exposed ports for local development
REDPANDA_EXTERNAL_PORT=19092
SCHEMA_REGISTRY_EXTERNAL_PORT=18081
PANDAPROXY_EXTERNAL_PORT=18082
REDPANDA_ADMIN_EXTERNAL_PORT=19644
REDPANDA_CONSOLE_EXTERNAL_PORT=18080
MINIO_API_EXTERNAL_PORT=19000
MINIO_CONSOLE_EXTERNAL_PORT=19001
POSTGRES_EXTERNAL_PORT=15432
BACKEND_EXTERNAL_PORT=18088

# Topics
TOPIC_PHYSICS=acc.physics.v1
TOPIC_GRAPHICS=acc.graphics.v1
TOPIC_STATIC=acc.static.v1

# MinIO
MINIO_ENDPOINT=localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datalake-bronze
MINIO_USE_SSL=false

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_USER=acc_user
POSTGRES_PASSWORD=acc_password
POSTGRES_DB=acc_auth
POSTGRES_SSLMODE=disable

# Backend auth
BACKEND_HTTP_ADDR=:8088
BACKEND_JWT_SECRET=change-me-in-local-env
BACKEND_ACCESS_TOKEN_TTL=15m
BACKEND_REFRESH_TOKEN_TTL=168h
BACKEND_SESSION_TTL=720h

# Pipeline behavior
PRODUCER_FLUSH_INTERVAL=1s
CONSUMER_WINDOW=5m
USER_STORAGE_PATH=./data/users.json
BADGER_PATH=./data/badger
